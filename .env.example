# Anthropic API Key (required)
OPENAI_API_KEY=sjdjeidefef
# Model configuration
# SOLVER_MODEL=claude-sonnet-4-20250514
# CRITIC_MODEL=claude-sonnet-4-20250514
# OPTIMIZER_MODEL=claude-sonnet-4-20250514
# GRADER_MODEL=claude-sonnet-4-20250514
SOLVER_MODEL=gpt-4o
CRITIC_MODEL=gpt-4o
OPTIMIZER_MODEL=gpt-4o-mini
GRADER_MODEL=gpt-4o
# RL Environment Settings
MAX_EPISODES=50
MAX_STEPS_PER_EPISODE=5
LEARNING_RATE=0.1
REWARD_THRESHOLD=0.85

# Memory Settings
MEMORY_FILE=./memory/agent_memory.json
MEMORY_MAX_ENTRIES=500
MEMORY_COMPRESSION_THRESHOLD=300

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/rl_env.log
ENABLE_PRETTY_LOGS=true

# Task Settings
TASK_CATEGORIES=coding,math,reasoning,writing,analysis
DIFFICULTY_LEVELS=easy,medium,hard
